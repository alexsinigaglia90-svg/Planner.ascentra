// Prisma schema — Planner Ascentra
// Provider: PostgreSQL (Vercel + Neon or any managed Postgres)
// Local dev: set DATABASE_URL to a local or Docker postgres connection string
// Production: set DATABASE_URL in Vercel environment variables

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Organization
// ---------------------------------------------------------------------------

model Organization {
  id           String                   @id @default(cuid())
  name         String
  slug         String                   @unique
  createdAt    DateTime                 @default(now())
  members      OrganizationMembership[]
  employees    Employee[]
  shiftTemplates ShiftTemplate[]
  rosterDays   RosterDay[]
  assignments  Assignment[]
  shiftRequirements ShiftRequirement[]
  skills       Skill[]
  locations    Location[]
  departments  Department[]
  employeeFunctions EmployeeFunction[]
  teams        Team[]
  auditLogs    AuditLog[]
  notifications Notification[]
  deliveryLogs  DeliveryLog[]
  processes     Process[]
  leaveRecords  LeaveRecord[]
  copilotAdvice    CopilotAdvice[]
  volumeForecasts  VolumeForecast[]
  volumeActuals    VolumeActual[]
  breakCovers      ProcessBreakCover[]
  skillReviews  SkillReview[]
  tempRequests  TempRequest[]
  agencyUploadTokens AgencyUploadToken[]
}

// ---------------------------------------------------------------------------
// User
// ---------------------------------------------------------------------------

model User {
  id           String                   @id @default(cuid())
  name         String
  email        String                   @unique
  password     String?                  // bcrypt hash; set on creation, required for login
  status       String                   @default("active") // "active" | "invited" | "disabled"
  createdAt    DateTime                 @default(now())
  memberships  OrganizationMembership[]
  inviteTokens InviteToken[]
  resetTokens  PasswordResetToken[]
  notifications Notification[]
}

// ---------------------------------------------------------------------------
// OrganizationMembership
// ---------------------------------------------------------------------------

model OrganizationMembership {
  id             String       @id @default(cuid())
  user           User         @relation(fields: [userId], references: [id])
  userId         String
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  role           String       @default("viewer") // "admin" | "planner" | "viewer"
  createdAt      DateTime     @default(now())

  @@unique([userId, organizationId])
}

// ---------------------------------------------------------------------------
// Employee
// ---------------------------------------------------------------------------

model Employee {
  id            String       @id @default(cuid())
  organization  Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  name          String
  email         String
  employeeType  String       @default("internal") // "internal" | "temp"
  contractHours Float        @default(0)
  status        String       @default("active")   // "active" | "inactive"
  assignments   Assignment[]
  createdAt     DateTime     @default(now())
  skills        EmployeeSkill[]
  location      Location?    @relation(fields: [locationId], references: [id])
  locationId    String?
  department    Department?  @relation(fields: [departmentId], references: [id])
  departmentId  String?
  employeeFunction EmployeeFunction? @relation(fields: [functionId], references: [id])
  functionId    String?
  team          Team?        @relation(fields: [teamId], references: [id])
  teamId        String?
  processScores EmployeeProcessScore[]
  leaveRecords  LeaveRecord[]
  skillReviews  SkillReview[]
  fixedWorkingDays String[] // Array of ISO weekday strings, e.g. ["Monday", "Tuesday"]

  @@unique([organizationId, email])
}

// ---------------------------------------------------------------------------
// ShiftTemplate — reusable, recurring shift definition (e.g. Morning 06:00–14:00)
// ---------------------------------------------------------------------------

model ShiftTemplate {
  id                String             @id @default(cuid())
  organization      Organization       @relation(fields: [organizationId], references: [id])
  organizationId    String
  name              String
  startTime         String             // "HH:MM" — stored as string for D1/SQLite compatibility
  endTime           String             // "HH:MM"
  requiredEmployees Int                @default(1)
  requiredSkill     Skill?             @relation(fields: [requiredSkillId], references: [id])
  requiredSkillId   String?
  location          Location?          @relation(fields: [locationId], references: [id])
  locationId        String?
  department        Department?        @relation(fields: [departmentId], references: [id])
  departmentId      String?
  // Break configuration
  breakMinutes      Int                @default(30)      // break duration in minutes
  breakMode         String             @default("all")   // "all" | "rotating" | "individual"
  breakWindowStart  String?            // "HH:MM" — when the break block starts (optional)

  assignments       Assignment[]
  requirements      ShiftRequirement[]
  rotationSlots     TeamRotationSlot[]
  tempRequests      TempRequest[]
}

// ---------------------------------------------------------------------------
// ShiftRequirement — org-level staffing requirement per shift template
// ---------------------------------------------------------------------------

model ShiftRequirement {
  id                String        @id @default(cuid())
  organization      Organization  @relation(fields: [organizationId], references: [id])
  organizationId    String
  shiftTemplate     ShiftTemplate @relation(fields: [shiftTemplateId], references: [id], onDelete: Cascade)
  shiftTemplateId   String
  requiredHeadcount Int           @default(1)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([organizationId, shiftTemplateId])
}

// ---------------------------------------------------------------------------
// Skill — an org-scoped function / competency label
// ---------------------------------------------------------------------------

model Skill {
  id              String          @id @default(cuid())
  organization    Organization    @relation(fields: [organizationId], references: [id])
  organizationId  String
  name            String
  employeeSkills  EmployeeSkill[]
  shiftTemplates  ShiftTemplate[]
  processes       Process[]
  createdAt       DateTime        @default(now())

  @@unique([organizationId, name])
}

// ---------------------------------------------------------------------------
// EmployeeSkill — many-to-many join: which skills an employee holds
// ---------------------------------------------------------------------------

model EmployeeSkill {
  id          String   @id @default(cuid())
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId  String
  skill       Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  skillId     String
  createdAt   DateTime @default(now())

  @@unique([employeeId, skillId])
}

// ---------------------------------------------------------------------------
// Location — a physical site / office / warehouse scoped to an organization
// ---------------------------------------------------------------------------

model Location {
  id              String          @id @default(cuid())
  organization    Organization    @relation(fields: [organizationId], references: [id])
  organizationId  String
  name            String
  employees       Employee[]
  shiftTemplates  ShiftTemplate[]
  createdAt       DateTime        @default(now())

  @@unique([organizationId, name])
}

// ---------------------------------------------------------------------------
// EmployeeFunction — a job function / role label scoped to an organization
// e.g. "Operator", "Teamleader", "Logistics" (overhead: true)
// ---------------------------------------------------------------------------

model EmployeeFunction {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  name           String
  overhead       Boolean      @default(false)
  archived       Boolean      @default(false)
  employees      Employee[]
  createdAt      DateTime     @default(now())

  @@unique([organizationId, name])
}

// ---------------------------------------------------------------------------
// Department — a functional team / cost centre scoped to an organization
//
// Hierarchy support (optional parent/child):
//   A Department with parentDepartmentId == null is a top-level (main) department.
//   A Department with a non-null parentDepartmentId is a subdepartment.
//   Only one level of nesting is enforced by convention; the schema allows
//   deeper trees but the application treats depth > 1 as flat subdepartments.
// ---------------------------------------------------------------------------

model Department {
  id                 String          @id @default(cuid())
  organization       Organization    @relation(fields: [organizationId], references: [id])
  organizationId     String
  name               String
  archived           Boolean         @default(false)
  employees          Employee[]
  shiftTemplates     ShiftTemplate[]
  processes          Process[]
  tempRequests       TempRequest[]
  createdAt          DateTime        @default(now())

  // Self-referential hierarchy
  parentDepartmentId String?
  parent             Department?     @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  children           Department[]    @relation("DepartmentHierarchy")

  @@unique([organizationId, name])
}

// ---------------------------------------------------------------------------
// Process — a warehouse/operations process type (e.g. Picking, Packing)
// Used as columns in the employee performance skill matrix.
// Scoped per organisation; color optional for heatmap column headers.
// ---------------------------------------------------------------------------

model Process {
  id             String               @id @default(cuid())
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  name           String
  color          String?              // optional hex colour for column header, e.g. "#6366f1"
  sortOrder      Int                  @default(0)
  active         Boolean              @default(true)
  // Planning fields
  department     Department?          @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  departmentId   String?
  normUnit       String?              // unit name, e.g. "Orderlines" or a custom label
  normPerHour    Int?
  minStaff       Int?                 // null = no minimum
  maxStaff       Int?                 // null = unlimited
  requiredSkill  Skill?               @relation(fields: [requiredSkillId], references: [id], onDelete: SetNull)
  requiredSkillId String?
  // Operating hours — when does this process run? (null = follows shift)
  activeStartTime String?             // "HH:MM" — process starts (null = shift start)
  activeEndTime   String?             // "HH:MM" — process ends (null = shift end)
  // Break behaviour
  breakPriority   String   @default("normal")  // "critical" | "normal" | "flexible"
  // Break cover: this process receives cover FROM other processes (via ProcessBreakCover)
  breakCoverTargets ProcessBreakCover[] @relation("BreakCoverTarget")
  breakCoverSources ProcessBreakCover[] @relation("BreakCoverSource")
  createdAt      DateTime             @default(now())
  scores           EmployeeProcessScore[]
  skillReviews     SkillReview[]
  volumeForecasts  VolumeForecast[]
  volumeActuals    VolumeActual[]

  @@unique([organizationId, name])
  @@index([organizationId, sortOrder])
}

// ---------------------------------------------------------------------------
// ProcessBreakCover — defines which flexible process sends people to which
// critical process during break blocks.
// ---------------------------------------------------------------------------

model ProcessBreakCover {
  id               String       @id @default(cuid())
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId   String
  sourceProcess    Process      @relation("BreakCoverSource", fields: [sourceProcessId], references: [id], onDelete: Cascade)
  sourceProcessId  String       // the flexible process that donates people
  targetProcess    Process      @relation("BreakCoverTarget", fields: [targetProcessId], references: [id], onDelete: Cascade)
  targetProcessId  String       // the critical process that receives cover
  headcount        Int          @default(1)  // how many people move over

  @@unique([organizationId, sourceProcessId, targetProcessId])
}

// ---------------------------------------------------------------------------
// EmployeeProcessScore — performance score (0–100) for an employee × process
// ---------------------------------------------------------------------------

model EmployeeProcessScore {
  id             String       @id @default(cuid())
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId     String
  process        Process      @relation(fields: [processId], references: [id], onDelete: Cascade)
  processId      String
  organizationId String       // denormalised for org-scoped queries
  score          Int          @default(0)   // legacy 0–100, kept for data safety
  level          Int          @default(0)   // 0–4 capability level (0=Not trained…4=Elite)
  updatedAt      DateTime     @updatedAt

  @@unique([employeeId, processId])
  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// LeaveRecord — tracks employee leave (vacation, personal) and absence (sick)
//
// type:     'leave' = planned (vacation, personal day, unpaid)
//           'absence' = unplanned (sick, emergency, other)
// category: 'vacation' | 'personal' | 'unpaid' | 'sick' | 'emergency' | 'other'
// status:   'pending' | 'approved' | 'rejected' (leave only; absence is always 'approved')
// ---------------------------------------------------------------------------

model LeaveRecord {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId     String
  type           String       // 'leave' | 'absence'
  category       String       // 'vacation' | 'personal' | 'unpaid' | 'sick' | 'emergency' | 'other'
  startDate      String       // YYYY-MM-DD
  endDate        String       // YYYY-MM-DD
  status         String       @default("pending") // 'pending' | 'approved' | 'rejected'
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([employeeId])
  @@index([organizationId, startDate, endDate])
}

// ---------------------------------------------------------------------------
// Team (Ploeg) — a rotating group of employees (e.g. Ploeg A / B / C)
//
// Rotation mechanics
//   rotationAnchorDate : the ISO Monday of week-0 of the rotation schedule,
//                        stored as "YYYY-MM-DD"
//   rotationLength     : how many unique weeks exist before the cycle repeats
//   rotationSlots      : one row per weekOffset (0 … rotationLength-1) mapping
//                        an offset to a ShiftTemplate
//
// To determine which shift a team works on a given date:
//   isoWeek = floor((date - anchorDate) / 7)
//   weekOffset = ((isoWeek % rotationLength) + rotationLength) % rotationLength
//   activeShift = rotationSlots.find(s => s.weekOffset === weekOffset)
// ---------------------------------------------------------------------------

model Team {
  id                  String             @id @default(cuid())
  organization        Organization       @relation(fields: [organizationId], references: [id])
  organizationId      String
  name                String             // e.g. "Ploeg A"
  color               String?            // optional hex colour for UI, e.g. "#4f46e5"
  rotationAnchorDate  String             // "YYYY-MM-DD" — Monday of week-0
  rotationLength      Int                @default(3)
  employees           Employee[]
  rotationSlots       TeamRotationSlot[]
  createdAt           DateTime           @default(now())

  @@unique([organizationId, name])
}

// ---------------------------------------------------------------------------
// TeamRotationSlot — maps a week position in the rotation to a shift template
// ---------------------------------------------------------------------------

model TeamRotationSlot {
  id              String        @id @default(cuid())
  team            Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId          String
  weekOffset      Int           // 0, 1, 2, …  (position inside the cycle)
  shiftTemplate   ShiftTemplate @relation(fields: [shiftTemplateId], references: [id])
  shiftTemplateId String

  @@unique([teamId, weekOffset])
}

// --------------------------------------------------------------------------- — a specific calendar date in the planning schedule
// ---------------------------------------------------------------------------

model RosterDay {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  date           String       // "YYYY-MM-DD" — stored as string for D1/SQLite compatibility
  assignments    Assignment[]
  createdAt      DateTime     @default(now())

  @@unique([organizationId, date])
}

// ---------------------------------------------------------------------------
// Assignment — the real planning record: who works which shift on which day
// ---------------------------------------------------------------------------

model Assignment {
  id               String        @id @default(cuid())
  organization     Organization  @relation(fields: [organizationId], references: [id])
  organizationId   String
  rosterDay        RosterDay     @relation(fields: [rosterDayId], references: [id], onDelete: Cascade)
  rosterDayId      String
  shiftTemplate    ShiftTemplate @relation(fields: [shiftTemplateId], references: [id])
  shiftTemplateId  String
  employee         Employee      @relation(fields: [employeeId], references: [id])
  employeeId       String
  notes            String?

  // An employee can only be assigned once to a given shift template on any roster day
  @@unique([rosterDayId, shiftTemplateId, employeeId])
}

// ---------------------------------------------------------------------------
// AuditLog — immutable change history for planner mutations
// ---------------------------------------------------------------------------

// ---------------------------------------------------------------------------
// InviteToken — one-time activation tokens for invited users
// ---------------------------------------------------------------------------

model InviteToken {
  id        String    @id @default(cuid())
  token     String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  usedAt    DateTime? // null = unused
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ---------------------------------------------------------------------------
// PasswordResetToken — one-time password-reset tokens for existing users
// ---------------------------------------------------------------------------

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  usedAt    DateTime? // null = unused
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Notification — in-app alerts for operational and account events
// ---------------------------------------------------------------------------

model Notification {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  type           String       // e.g. "understaffed", "no_skill_match", "over_hours", "user_invited", "password_reset"
  title          String
  message        String
  status         String       @default("unread") // "unread" | "read"
  severity       String       @default("info")   // "info" | "warning" | "critical"
  createdAt      DateTime     @default(now())

  @@index([organizationId, userId, status])
  @@index([organizationId, userId, createdAt])
}

// ---------------------------------------------------------------------------

model AuditLog {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  userId         String
  actionType     String       // e.g. "create_assignment", "delete_assignment", "autofill"
  entityType     String       // e.g. "assignment", "requirement"
  entityId       String       // primary entity affected
  summary        String       // human-readable one-liner
  beforeData     String?      // JSON snapshot before change
  afterData      String?      // JSON snapshot after change
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, entityType, entityId])
  @@index([organizationId, actionType])
  @@index([organizationId, userId])
}

// ---------------------------------------------------------------------------
// DeliveryLog — outbound transactional message tracking
// ---------------------------------------------------------------------------

model DeliveryLog {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  userId         String?      // target user, if applicable (plain id — not FK to survive user deletion)
  type           String       // "invite" | "password_reset" | "staffing_alert"
  recipient      String       // email address
  subject        String
  templateData   String       // JSON blob of template variables
  status         String       @default("queued") // "queued" | "sent" | "failed" | "simulated"
  errorMessage   String?
  retryCount     Int          @default(0)
  nextRetryAt    DateTime?    // null = ready to send; future = waiting for retry window
  createdAt      DateTime     @default(now())
  sentAt         DateTime?

  @@index([organizationId, createdAt])
  @@index([organizationId, status])
  @@index([status, nextRetryAt])   // queue scan index
}

// ---------------------------------------------------------------------------
// CopilotAdvice — AI-driven operational insights with lifecycle tracking
//
// type:     category of advice
// priority: 1 (critical) to 5 (low)
// status:   lifecycle state
// estimatedSavings: monthly € impact (nullable for non-cost insights)
// ---------------------------------------------------------------------------

// ---------------------------------------------------------------------------
// AgencyUploadToken — shareable link for agencies to upload temp employee data
//
// The org creates a token with an expiry. The agency uses the public URL
// /agency/upload/[token] to upload a CSV without needing an account.
// ---------------------------------------------------------------------------

model AgencyUploadToken {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  token          String       @unique
  agencyName     String       // e.g. "Randstad"
  agencyEmail    String?
  expiresAt      DateTime
  usedAt         DateTime?    // set when agency uploads
  uploadedCount  Int?         // number of temps uploaded
  createdBy      String       // userId
  createdByName  String
  notes          String?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([token])
}

// ---------------------------------------------------------------------------
// TempRequest — temp staffing request with approval workflow
//
// Lifecycle: draft → pending → approved → sent_to_agency → confirmed
//            draft → pending → rejected
//
// urgency: 'low' | 'medium' | 'high' | 'critical'
// ---------------------------------------------------------------------------

model TempRequest {
  id              String       @id @default(cuid())
  organization    Organization @relation(fields: [organizationId], references: [id])
  organizationId  String
  requestedBy     String       // userId who created the request
  requestedByName String       // denormalised for display
  // What is needed
  title           String       // short description, e.g. "3 uitzendkrachten voor ochtendshift"
  description     String?      // detailed reason/context
  quantity        Int          @default(1) // number of temps needed
  shiftTemplate   ShiftTemplate? @relation(fields: [shiftTemplateId], references: [id])
  shiftTemplateId String?
  department      Department?  @relation(fields: [departmentId], references: [id])
  departmentId    String?
  // When
  startDate       String       // YYYY-MM-DD
  endDate         String       // YYYY-MM-DD
  urgency         String       @default("medium") // 'low' | 'medium' | 'high' | 'critical'
  // Lifecycle
  status          String       @default("draft") // 'draft' | 'pending' | 'approved' | 'rejected' | 'sent_to_agency' | 'confirmed'
  // Approval
  approvedBy      String?      // userId who approved/rejected
  approvedByName  String?
  approvedAt      DateTime?
  rejectionReason String?
  // Agency
  agencyName      String?      // e.g. "Randstad", "Manpower"
  agencyEmail     String?
  sentToAgencyAt  DateTime?
  agencyResponse  String?      // free text response from agency
  confirmedAt     DateTime?
  // Meta
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

// ---------------------------------------------------------------------------
// SkillReview — periodic skill/process reviews ("Tinder for Skills")
//
// verdict: 'improved' | 'same' | 'declined'
// Tracks trends over time. After N consecutive same verdicts, the
// EmployeeProcessScore.level is auto-adjusted (3x improved → +1, 2x declined → -1).
// period: e.g. "2026-Q1" or "2026-03" — groups reviews for analytics
// ---------------------------------------------------------------------------

model SkillReview {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId     String
  process        Process      @relation(fields: [processId], references: [id], onDelete: Cascade)
  processId      String
  previousLevel  Int          // level at time of review (0-4)
  verdict        String       // 'improved' | 'same' | 'declined'
  newLevel       Int          // level after review (may change if streak threshold hit)
  reviewedBy     String       // userId of reviewer
  period         String       // e.g. "2026-Q1" for analytics grouping
  createdAt      DateTime     @default(now())

  @@index([organizationId, period])
  @@index([organizationId, employeeId])
  @@index([organizationId, processId])
  @@index([employeeId, processId, createdAt])
}

model CopilotAdvice {
  id                String       @id @default(cuid())
  organization      Organization @relation(fields: [organizationId], references: [id])
  organizationId    String
  type              String       // 'cost_saving' | 'risk_warning' | 'training' | 'staffing' | 'compliance' | 'efficiency'
  priority          Int          @default(3) // 1=critical, 5=low
  title             String
  description       String
  action            String?      // suggested action text
  estimatedSavings  Float?       // €/month potential saving
  status            String       @default("active") // 'active' | 'seen' | 'accepted' | 'declined' | 'expired' | 'completed'
  departmentId      String?
  departmentName    String?
  processId         String?
  employeeId        String?
  metadata          String?      // JSON string for extra context
  createdAt         DateTime     @default(now())
  seenAt            DateTime?
  respondedAt       DateTime?
  completedAt       DateTime?
  actualSavings     Float?       // measured outcome after implementation

  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([organizationId, createdAt])
}

// ---------------------------------------------------------------------------
// VolumeForecast — daily volume targets per process (S&OP integration)
// Links to Process.normPerHour for automatic demand → FTE conversion.
// ---------------------------------------------------------------------------

model VolumeForecast {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  process        Process      @relation(fields: [processId], references: [id], onDelete: Cascade)
  processId      String
  date           String       // YYYY-MM-DD
  volume         Float        // target volume in process normUnit
  source         String       @default("manual")   // "manual" | "import" | "api"
  confidence     String       @default("firm")      // "firm" | "provisional"
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, processId, date])
  @@index([organizationId, date])
  @@index([processId, date])
}

// ---------------------------------------------------------------------------
// VolumeActual — realized volume per process (for forecast accuracy tracking)
// ---------------------------------------------------------------------------

model VolumeActual {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  process        Process      @relation(fields: [processId], references: [id], onDelete: Cascade)
  processId      String
  date           String       // YYYY-MM-DD
  volume         Float        // actual realized volume
  createdAt      DateTime     @default(now())

  @@unique([organizationId, processId, date])
  @@index([organizationId, date])
}

