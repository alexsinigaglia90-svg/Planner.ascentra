# ── Database ─────────────────────────────────────────────────────────────────
# Local: use a local or Docker PostgreSQL instance
#   docker run -e POSTGRES_PASSWORD=dev -p 5432:5432 postgres
DATABASE_URL="postgresql://postgres:dev@localhost:5432/planner_ascentra"

# Production (Vercel): use a managed PostgreSQL service, e.g. Neon
# DATABASE_URL="postgresql://<user>:<password>@<host>/<dbname>?sslmode=require"

# ── Session ──────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -base64 32
SESSION_SECRET="change-this-to-a-strong-random-value-at-least-32-chars"

# ── Seed ─────────────────────────────────────────────────────────────────────
# Default admin password used by bootstrap.ts — change after first login
SEED_ADMIN_PASSWORD="change-in-production"

# ── SMTP (email delivery) ────────────────────────────────────────────────────
# Leave unset to run in simulation mode (emails logged to console, not sent)
SMTP_HOST="smtp.office365.com"
SMTP_PORT="587"
# SMTP_SECURE="true"   # only for port 465 (SSL); omit or leave blank for STARTTLS
SMTP_USER="your-smtp-username@example.com"
SMTP_PASS="your-smtp-password"
MAIL_FROM="Planner Ascentra <no-reply@example.com>"

# ── Delivery cron ────────────────────────────────────────────────────────────
# Must match the CRON_SECRET GitHub Actions repository secret.
# Generate with: openssl rand -base64 32
CRON_SECRET="change-this-to-a-strong-random-value"
