# Local development
DATABASE_URL="file:./prisma/dev.db"

# Cloudflare D1 (production)
# D1 is bound via wrangler.toml — no DATABASE_URL needed at runtime.
# Configure the binding in wrangler.toml:
#
# [[d1_databases]]
# binding = "DB"
# database_name = "planner-ascentra"
# database_id = "<your-d1-database-id>"
